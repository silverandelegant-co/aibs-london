<!-- ROOT-LEVEL DISTRACTION-FREE FULLSCREEN EDITOR MODAL -->
<div x-show="fullscreenEditorOpen" 
  class="fixed inset-0 z-[150] bg-slate-950 flex flex-col p-8 space-y-4"
  x-transition:enter="transition ease-out duration-200"
  x-transition:enter-start="opacity-0 scale-95"
  x-transition:enter-end="opacity-100 scale-100"
  x-transition:leave="transition ease-in duration-150"
  x-transition:leave-start="opacity-100 scale-100"
  x-transition:leave-end="opacity-0 scale-95"
  x-cloak>
  
  <!-- Modal Header -->
  <div class="flex items-center justify-between border-b border-slate-800 pb-4">
    <div>
      <h3 class="font-serif text-xl font-semibold text-gold-300" x-text="fullscreenEditorTitle"></h3>
      <p class="text-xs text-slate-500" x-text="fullscreenEditorSubtitle"></p>
    </div>
    <div class="flex items-center space-x-3">
      <button @click="closeFullscreenEditor(false)" class="px-4 py-2 bg-slate-900 border border-slate-800 hover:border-slate-700 text-slate-400 hover:text-slate-200 text-xs font-semibold rounded-xl">İptal / Vazgeç</button>
      <button @click="closeFullscreenEditor(true)" class="px-5 py-2 bg-gold-500 hover:bg-gold-400 text-slate-950 text-xs font-semibold rounded-xl tracking-wide flex items-center space-x-1.5 shadow-lg shadow-gold-500/10">
        <i class="fa-solid fa-check"></i>
        <span>Değişiklikleri Uygula</span>
      </button>
    </div>
  </div>

  <!-- Editor Container -->
  <div 
    class="quill-wysiwyg-wrapper flex-grow flex flex-col h-[calc(100vh-160px)]"
    x-init="
      const watch = $watch;
      $nextTick(() => {
        const container = $el.querySelector('.quill-editor');
        const quill = new Quill(container, {
          theme: 'snow',
          modules: {
            toolbar: [
              ['bold', 'italic', 'underline'],
              [{ 'header': [1, 2, 3, false] }],
              [{ 'list': 'ordered'}, { 'list': 'bullet' }],
              ['link', 'image', 'clean']
            ]
          }
        });
        
        quill.getModule('toolbar').addHandler('image', () => {
          openMediaLibraryModal('quill', quill);
        });
        
        const turndownService = new TurndownService({ headingStyle: 'atx' });
        quill.on('text-change', (delta, oldDelta, source) => {
          if (source === 'user') {
            fullscreenEditorContent = turndownService.turndown(quill.root.innerHTML);
          }
        });
        
        watch('fullscreenEditorContent', (newVal) => {
          const currentMarkdown = turndownService.turndown(quill.root.innerHTML);
          if (newVal !== currentMarkdown) {
            quill.root.innerHTML = marked.parse(newVal || '');
          }
        });

        watch('fullscreenEditorOpen', (isOpen) => {
          if (isOpen) {
            quill.root.innerHTML = marked.parse(fullscreenEditorContent || '');
            setTimeout(() => quill.focus(), 150);
          }
        });
      });
    "
  >
    <div class="quill-editor flex-grow bg-slate-900/40 border border-slate-800/80 rounded-xl" style="height: 100%;"></div>
  </div>
</div>
