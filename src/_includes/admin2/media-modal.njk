<!-- PREMIUM CUSTOM MEDIA LIBRARY MODAL -->
<div x-show="mediaLibraryOpen" class="fixed inset-0 overflow-hidden z-[9999]" x-cloak>
  <div class="absolute inset-0 bg-slate-950/80 backdrop-blur-md" @click="mediaLibraryOpen = false"></div>
  
  <div class="absolute inset-x-4 inset-y-12 md:inset-x-20 md:inset-y-16 bg-slate-900 border border-slate-800 rounded-2xl shadow-2xl flex flex-col overflow-hidden max-w-4xl mx-auto">
    <!-- Modal Header -->
    <div class="px-6 py-5 border-b border-slate-800 bg-slate-950 flex items-center justify-between flex-shrink-0">
      <div>
        <h3 class="font-serif text-lg font-semibold text-gold-300">Medya Kütüphanesi</h3>
        <p class="text-[10px] text-slate-500 mt-0.5">Mevcut görselleri seçin ya da doğrudan deponuza yeni bir görsel yükleyin.</p>
      </div>
      <button @click="mediaLibraryOpen = false" class="text-slate-400 hover:text-slate-200 text-lg"><i class="fa-solid fa-times"></i></button>
    </div>

    <!-- Toolbar: Upload & Search -->
    <div class="px-6 py-4 bg-slate-950/40 border-b border-slate-800 flex flex-col md:flex-row md:items-center justify-between gap-4 flex-shrink-0">
      <!-- Search input -->
      <div class="relative flex-grow max-w-sm">
        <i class="fa-solid fa-search text-slate-500 absolute left-3.5 top-3"></i>
        <input type="text" x-model="mediaSearchQuery" placeholder="Görsel adına göre ara..."
          class="w-full bg-slate-950 border border-slate-800 rounded-xl py-2 pl-9 pr-4 text-xs text-slate-300 focus:outline-none" />
      </div>

      <!-- Selected Items Actions (Sveltia style!) -->
      <div x-show="activeSelectedImages.length > 0" x-cloak class="flex flex-wrap items-center gap-1.5 bg-slate-900/60 border border-slate-800/80 px-2.5 py-1 rounded-xl transition-all duration-300">
        <span class="text-[9px] font-bold text-slate-400 mr-1 bg-slate-950 px-2 py-0.5 rounded border border-slate-850 font-mono">
          <span x-text="activeSelectedImages.length"></span> Seçildi
        </span>
        
        <!-- Önizleme -->
        <button @click="previewSelectedMedia()" class="p-1.5 hover:bg-slate-850 text-slate-400 hover:text-gold-400 text-xs font-semibold rounded-lg flex items-center gap-1.5 transition-colors" title="Önizle">
          <i class="fa-solid fa-eye text-gold-500/80"></i>
          <span class="hidden lg:inline text-[10px]">Önizle</span>
        </button>
        
        <!-- Kopyala Dropdown -->
        <div x-data="{ open: false }" class="relative inline-block text-left">
          <button @click="open = !open" @click.away="open = false" 
            class="p-1.5 hover:bg-slate-850 text-slate-400 hover:text-gold-400 text-xs font-semibold rounded-lg flex items-center gap-1.5 transition-colors" title="Kopyala">
            <i class="fa-solid fa-copy text-gold-500/80"></i>
            <span class="hidden lg:inline text-[10px]">Kopyala</span>
            <i class="fa-solid fa-chevron-down text-[8px] text-slate-500"></i>
          </button>
          
          <div x-show="open" x-cloak
            class="absolute right-0 mt-2 w-48 rounded-xl bg-slate-950 border border-slate-850 shadow-2xl z-[99999] py-1 overflow-hidden transform origin-top-right transition-all">
            <button @click="copyMediaText('path'); open = false" class="w-full text-left px-4 py-2 text-[10px] text-slate-300 hover:bg-slate-900 hover:text-gold-400 transition-colors">Dosya Yolu (/assets/...)</button>
            <button @click="copyMediaText('markdown'); open = false" class="w-full text-left px-4 py-2 text-[10px] text-slate-300 hover:bg-slate-900 hover:text-gold-400 transition-colors">Markdown Kodu</button>
            <button @click="copyMediaText('html'); open = false" class="w-full text-left px-4 py-2 text-[10px] text-slate-300 hover:bg-slate-900 hover:text-gold-400 transition-colors">HTML Etiketi</button>
          </div>
        </div>
        
        <!-- İndir -->
        <button @click="downloadSelectedMedia()" class="p-1.5 hover:bg-slate-850 text-slate-400 hover:text-gold-400 text-xs font-semibold rounded-lg flex items-center gap-1.5 transition-colors" title="İndir">
          <i class="fa-solid fa-download text-gold-500/80"></i>
          <span class="hidden lg:inline text-[10px]">İndir</span>
        </button>
        
        <!-- Sil -->
        <button @click="deleteSelectedMedia()" class="p-1.5 hover:bg-red-950/20 text-slate-550 hover:text-red-400 text-xs font-semibold rounded-lg flex items-center gap-1.5 transition-colors" title="Kalıcı Olarak Sil">
          <i class="fa-solid fa-trash text-red-500/75"></i>
          <span class="hidden lg:inline text-[10px]">Sil</span>
        </button>
      </div>

      <!-- Direct Upload file input -->
      <div class="flex items-center space-x-2">
        <label class="cursor-pointer px-4 py-2 bg-gold-500 hover:bg-gold-400 text-slate-950 text-xs font-bold rounded-xl flex items-center space-x-1.5 transition-all shadow-md shadow-gold-500/10">
          <i class="fa-solid fa-arrow-up-from-bracket"></i>
          <span>Yeni Görsel Yükle</span>
          <input type="file" @change="uploadNewImage($event)" class="hidden" accept="image/*" />
        </label>
      </div>
    </div>

    <!-- Grid Body -->
    <div class="flex-grow p-6 overflow-y-auto bg-slate-950/20">
      <!-- Loading spinner specific to media -->
      <div x-show="mediaLoading" class="flex flex-col items-center justify-center py-12">
        <div class="w-8 h-8 rounded-full border-2 border-slate-800 border-t-gold-500 animate-spin"></div>
        <span class="text-xs text-slate-500 mt-3 font-mono">Görseller yükleniyor...</span>
      </div>

      <div x-show="!mediaLoading" class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-5 gap-4">
        <template x-for="file in filteredMediaFiles()" :key="file.path">
          <div class="group border rounded-xl overflow-hidden flex flex-col justify-between p-2 cursor-pointer transition-all relative select-none"
            :class="isMediaSelected(file) ? 'border-gold-500/80 bg-slate-950 ring-1 ring-gold-500/30' : 'border-slate-850 bg-slate-950 hover:border-gold-500/30'"
            @click="toggleMediaSelection(file)"
            @dblclick="activeSelectedImages = ['/' + file.path.replace(/^\/+/, '')]; insertSelectedMedia()">
            
            <!-- Pending / Staged Badge -->
            <template x-if="file.isPending">
              <div class="absolute top-2 left-2 px-1.5 py-0.5 bg-amber-500 text-slate-950 text-[8px] font-bold rounded flex items-center gap-1 z-10 select-none shadow">
                <i class="fa-solid fa-clock animate-pulse"></i>
                <span>Yayınlanmadı</span>
              </div>
            </template>

            <!-- Tick Indicator if selected -->
            <div x-show="isMediaSelected(file)" x-cloak class="absolute top-2 right-2 w-5 h-5 bg-gold-500 rounded-full flex items-center justify-center text-slate-950 text-[10px] z-10 font-bold shadow-md shadow-gold-500/20">
              <i class="fa-solid fa-check"></i>
            </div>

            <!-- Thumbnail -->
            <div class="w-full aspect-square bg-slate-900 rounded-lg overflow-hidden flex items-center justify-center border border-slate-800 group-hover:scale-[1.01] transition-transform">
              <img :src="file.isPending ? file.blobUrl : `https://raw.githubusercontent.com/${repoOwner}/${repoName}/${branch}/${file.rawPath || ('src/' + file.path)}`" class="w-full h-full object-cover" onerror="this.src='https://placehold.co/100x100/1e293b/a88653?text=Hata'" />
            </div>
            <!-- Filename metadata -->
            <div class="mt-2 px-1">
              <span class="text-[9px] font-semibold text-slate-300 block truncate" :title="file.name" x-text="file.name"></span>
              <span class="text-[8px] text-slate-500 font-mono" x-text="formatBytes(file.size)"></span>
            </div>
          </div>
        </template>
      </div>

      <!-- Empty gallery state -->
      <div x-show="!mediaLoading && filteredMediaFiles().length === 0" class="text-center py-12 text-slate-500 text-xs">
        <i class="fa-solid fa-images text-2xl text-slate-700 mb-3 block"></i>
        Galeride aradığınız görsel bulunamadı.
      </div>
    </div>

    <!-- Modal Footer -->
    <div class="px-6 py-4 bg-slate-950 border-t border-slate-800 flex items-center justify-between flex-shrink-0">
      <span class="text-[10px] text-slate-500 leading-none">
        <template x-if="mediaTargetObject">
          <span>Seçtiğiniz görsel(ler)i form alanına eklemek için "Seçilenleri Ekle" butonuna basın veya görsele çift tıklayın.</span>
        </template>
        <template x-if="!mediaTargetObject">
          <span>Önizleme, Kopyalama, İndirme ve Silme işlemlerini kullanabilirsiniz.</span>
        </template>
      </span>
      <div class="flex items-center space-x-2">
        <button @click="mediaLibraryOpen = false" class="px-4 py-2.5 bg-slate-900 border border-slate-800 hover:border-slate-700 rounded-xl text-xs font-semibold text-slate-400 hover:text-slate-200 transition-all">Kapat</button>
        <template x-if="mediaTargetObject">
          <button @click="insertSelectedMedia()" :disabled="activeSelectedImages.length === 0"
            class="px-5 py-2.5 bg-gold-500 hover:bg-gold-400 disabled:opacity-40 disabled:cursor-not-allowed text-slate-950 text-xs font-bold rounded-xl flex items-center space-x-1.5 transition-all shadow-lg shadow-gold-500/10">
            <i class="fa-solid fa-circle-check"></i>
            <span>Seçilenleri Ekle</span>
          </button>
        </template>
      </div>
    </div>
  </div>
</div>
