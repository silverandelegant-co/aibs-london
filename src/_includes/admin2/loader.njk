<!-- Page Loader Spinner -->
<div x-show="globalLoading" class="fixed inset-0 bg-slate-950/80 backdrop-blur-md z-[99999] flex flex-col items-center justify-center">
  <div class="relative w-20 h-20">
    <div class="absolute inset-0 rounded-full border-4 border-slate-800"></div>
    <div class="absolute inset-0 rounded-full border-4 border-t-gold-500 animate-spin"></div>
  </div>
  <p class="mt-6 text-gold-300 font-serif tracking-widest text-lg animate-pulse" x-text="loadingText"></p>
</div>
