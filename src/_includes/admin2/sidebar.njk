<!-- SIDE NAVIGATION (RESPONSIVE) -->
<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>

<!-- 1. DESKTOP SIDEBAR VIEW -->
<aside class="hidden lg:block lg:w-64 flex-shrink-0">
  <nav class="space-y-1.5 sticky top-28">
    <button @click="activeCatalog = 'dashboard'" 
      class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl text-sm font-medium transition-all group"
      :class="activeCatalog === 'dashboard' ? 'bg-gold-500/10 text-gold-300 border border-gold-500/20' : 'text-slate-400 hover:bg-slate-900/50 hover:text-slate-200 border border-transparent'">
      <i class="fa-solid fa-chart-line text-base" :class="activeCatalog === 'dashboard' ? 'text-gold-400' : 'text-slate-500'"></i>
      <span>Genel Bakış</span>
    </button>
    
    <!-- Group: Web Sitesi İçeriği -->
    <div class="pt-4 pb-1.5 px-4">
      <span class="text-[10px] text-slate-600 font-semibold uppercase tracking-widest">Web Sitesi İçeriği</span>
    </div>
    
    <template x-for="cat in pagesCatalogs" :key="cat.name">
      <button @click="selectCatalog(cat.name)" 
        class="w-full flex items-center justify-between px-4 py-2.5 rounded-xl text-sm font-medium transition-all group"
        :class="activeCatalog === cat.name ? 'bg-gold-500/10 text-gold-300 border border-gold-500/20' : 'text-slate-400 hover:bg-slate-900/50 hover:text-slate-200 border border-transparent'">
        <div class="flex items-center space-x-3">
          <i class="fa-solid text-sm" :class="[
            cat.name === 'settings' ? 'fa-sliders' : '',
            cat.name === 'manifesto' ? 'fa-pen-nib' : '',
            cat.name === 'trust' ? 'fa-shield-halved' : '',
            cat.name === 'services' ? 'fa-briefcase' : '',
            activeCatalog === cat.name ? 'text-gold-400' : 'text-slate-500'
          ]"></i>
          <span x-text="cat.label"></span>
          <span x-show="cat.dirty" class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse" title="Yayınlanmamış değişiklikler var" x-cloak></span>
        </div>
      </button>
    </template>
  </nav>
</aside>

<!-- 2. MOBILE HORIZONTAL SWIPABLE TAB VIEW -->
<aside class="block lg:hidden w-full flex-shrink-0">
  <div class="flex overflow-x-auto no-scrollbar scroll-smooth gap-2 pb-3 -mx-4 px-4 border-b border-slate-900">
    
    <!-- Dashboard Button -->
    <button @click="activeCatalog = 'dashboard'" 
      class="flex-shrink-0 flex items-center space-x-1.5 px-3.5 py-2 rounded-full text-xs font-semibold border transition-all"
      :class="activeCatalog === 'dashboard' ? 'bg-gold-500/10 text-gold-300 border-gold-500/30' : 'bg-slate-900/60 border-slate-800/80 text-slate-400'">
      <i class="fa-solid fa-chart-line text-[10px]" :class="activeCatalog === 'dashboard' ? 'text-gold-400' : 'text-slate-500'"></i>
      <span>Genel Bakış</span>
    </button>

    <!-- Pages & Settings -->
    <template x-for="cat in pagesCatalogs" :key="cat.name">
      <button @click="selectCatalog(cat.name)" 
        class="flex-shrink-0 flex items-center space-x-1.5 px-3.5 py-2 rounded-full text-xs font-semibold border transition-all"
        :class="activeCatalog === cat.name ? 'bg-gold-500/10 text-gold-300 border-gold-500/30' : 'bg-slate-900/60 border-slate-800/80 text-slate-400'">
        <i class="fa-solid text-[10px]" :class="[
          cat.name === 'settings' ? 'fa-sliders' : '',
          cat.name === 'manifesto' ? 'fa-pen-nib' : '',
          cat.name === 'trust' ? 'fa-shield-halved' : '',
          cat.name === 'services' ? 'fa-briefcase' : '',
          activeCatalog === cat.name ? 'text-gold-400' : 'text-slate-500'
        ]"></i>
        <span x-text="cat.label"></span>
        <span x-show="cat.dirty" class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse" x-cloak></span>
      </button>
    </template>
  </div>
</aside>
