      initApp() {
        const savedToken = localStorage.getItem('admin_pat');
        if (savedToken) {
          this.token = savedToken;
          this.tokenInput = savedToken;
          this.isAuthenticated = true;
          this.loadAllCatalogs();
          this.loadMediaLibrary();
        }
      },

      async authenticate() {
        if (!this.tokenInput.trim()) {
          this.showToast('Lütfen geçerli bir GitHub Token (PAT) girin.', 'error');
          return;
        }
        this.showLoading('Token doğrulanıyor...');
        try {
          const res = await fetch(`https://api.github.com/repos/${this.repoOwner}/${this.repoName}`, {
            headers: { 'Authorization': `token ${this.tokenInput.trim()}` }
          });
          if (res.ok) {
            this.token = this.tokenInput.trim();
            localStorage.setItem('admin_pat', this.token);
            this.isAuthenticated = true;
            this.showToast('Giriş başarılı.', 'success');
            await this.loadAllCatalogs();
            await this.loadMediaLibrary();
          } else {
            throw new Error();
          }
        } catch (err) {
          this.showToast('Giriş başarısız. Token bilgilerinizi kontrol edin.', 'error');
        } finally {
          this.hideLoading();
        }
      },

