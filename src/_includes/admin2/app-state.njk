      // Media Library API Interactions
      async loadMediaLibrary() {
        this.mediaLoading = true;
        try {
          const res = await fetch(`https://api.github.com/repos/${this.repoOwner}/${this.repoName}/contents/src/assets?ref=${this.branch}`, {
            headers: { 'Authorization': `token ${this.token}` }
          });
          if (res.ok) {
            const files = await res.json();
            this.mediaFiles = files.filter(f => f.type === 'file' && /\.(jpg|jpeg|png|gif|webp|svg)$/i.test(f.name))
                                   .map(f => ({
                                     name: f.name,
                                     path: f.path.replace(/^src\//, ''), // matches Passthrough copy output path
                                     rawPath: f.path, // full repo path for raw.githubusercontent.com thumbnail
                                     sha: f.sha,
                                     size: f.size
                                   }));
          }
        } catch (err) {
          console.error(err);
        } finally {
          this.mediaLoading = false;
        }
      },

      filteredMediaFiles() {
        if (!this.mediaSearchQuery.trim()) return this.mediaFiles;
        const q = this.mediaSearchQuery.trim().toLowerCase();
        return this.mediaFiles.filter(f => f.name.toLowerCase().includes(q));
      },

      // Convert any Google Drive share URL to a direct embeddable image URL
      driveUrlToDirectLink(url) {
        if (!url) return '';
        if (url.includes('lh3.googleusercontent.com')) return url;
        
        let fileId = '';
        const fileMatch = url.match(/\/file\/d\/([a-zA-Z0-9_-]+)/);
        if (fileMatch) {
          fileId = fileMatch[1];
        } else {
          const openMatch = url.match(/(?:[?&]|&amp;)id=([a-zA-Z0-9_-]+)/);
          if (openMatch) {
            fileId = openMatch[1];
          }
        }
        
        if (fileId) {
          return `https://lh3.googleusercontent.com/d/${fileId}`;
        }
        return url;
      },

      resolveImagePath(path) {
        if (!path) return '';
        // Google Drive URL — convert to direct link
        if (path.includes('drive.google.com') || path.includes('googleusercontent.com')) {
          return this.driveUrlToDirectLink(path);
        }
        const clean = path.replace(/^\/+/, '');
        const pending = (this.pendingImageUploads || []).find(img => img.path === 'src/' + clean || img.path === clean || img.path.endsWith('/' + clean.split('/').pop()));
        if (pending) {
          return pending.blobUrl;
        }
        return path.startsWith('/') ? path : '/' + path;
      },

      // Returns the best displayable image URL for a piece (Drive > repo image)
      resolveFirstPieceImage(piece) {
        if (piece.drive_images && piece.drive_images.length > 0 && piece.drive_images[0]) {
          return this.driveUrlToDirectLink(piece.drive_images[0]);
        }
        if (piece.images && piece.images.length > 0 && piece.images[0]) {
          return this.resolveImagePath(piece.images[0]);
        }
        return 'https://placehold.co/100x100/1e293b/a88653?text=Görsel+Yok';
      },

      // Completely robust media modal open routine (Fixes header button NPE)
      openMediaLibraryModal(targetObj, propertyNameOrIndex) {
        this.mediaTargetObject = targetObj;
        
        let initialVal = '';
        if (typeof propertyNameOrIndex === 'number') {
          this.mediaTargetProperty = null;
          this.mediaTargetIndex = propertyNameOrIndex;
          initialVal = (targetObj && targetObj[propertyNameOrIndex]) ? targetObj[propertyNameOrIndex] : '';
        } else {
          this.mediaTargetProperty = propertyNameOrIndex || null;
          this.mediaTargetIndex = -1;
          initialVal = (targetObj && propertyNameOrIndex) ? (targetObj[propertyNameOrIndex] || '') : '';
        }
        
        // Initialize activeSelectedImages array with current value if exists
        this.activeSelectedImages = [];
        if (initialVal) {
          const pathWithSlash = '/' + initialVal.replace(/^\/+/, '');
          this.activeSelectedImages.push(pathWithSlash);
        }
        
        this.mediaSearchQuery = '';
        this.mediaLibraryOpen = true;
        this.loadMediaLibrary();
      },

      toggleMediaSelection(file) {
        const path = '/' + file.path.replace(/^\/+/, '');
        const index = this.activeSelectedImages.indexOf(path);
        if (index === -1) {
          this.activeSelectedImages.push(path);
        } else {
          this.activeSelectedImages.splice(index, 1);
        }
      },

      isMediaSelected(file) {
        const path = '/' + file.path.replace(/^\/+/, '');
        return this.activeSelectedImages.includes(path);
      },

      insertSelectedMedia() {
        if (this.activeSelectedImages.length === 0) {
          this.showToast('Lütfen en az bir görsel seçin.', 'error');
          return;
        }
        
        if (this.mediaTargetObject === 'quill') {
          const quill = this.mediaTargetProperty;
          const range = quill.getSelection();
          let index = range ? range.index : quill.getLength();
          
          this.activeSelectedImages.forEach(relativePath => {
            quill.insertEmbed(index, 'image', relativePath);
            index += 1;
          });
        } else if (this.mediaTargetIndex !== -1 && this.mediaTargetObject) {
          // Replace first slot
          this.mediaTargetObject[this.mediaTargetIndex] = this.activeSelectedImages[0];
          
          // Append remaining selected images to the array
          if (this.activeSelectedImages.length > 1 && Array.isArray(this.mediaTargetObject)) {
            for (let i = 1; i < this.activeSelectedImages.length; i++) {
              this.mediaTargetObject.push(this.activeSelectedImages[i]);
            }
          }
        } else if (this.mediaTargetProperty && this.mediaTargetObject) {
          this.mediaTargetObject[this.mediaTargetProperty] = this.activeSelectedImages[0];
        }
        
        this.mediaLibraryOpen = false;
        this.showToast('Görsel(ler) başarıyla eklendi.', 'success');
      },

      // Keep this for legacy / programmatic compatibility
      selectMediaFile(file) {
        const path = '/' + file.path.replace(/^\/+/, '');
        this.activeSelectedImages = [path];
        this.insertSelectedMedia();
      },

      deleteSelectedMedia() {
        if (this.activeSelectedImages.length === 0) return;
        
        const count = this.activeSelectedImages.length;
        if (!confirm(`Seçilen ${count} görseli silinmek üzere işaretlemek istediğinize emin misiniz? Yayınla butonuna bastığınızda kalıcı olarak silinecektir.`)) {
          return;
        }
        
        if (!this.pendingImageDeletes) this.pendingImageDeletes = [];
        
        this.activeSelectedImages.forEach(relativePath => {
          const cleanPath = relativePath.replace(/^\/+/, '');
          const file = this.mediaFiles.find(f => f.path === cleanPath || ('src/' + f.path) === cleanPath);
          
          // 1. If it was a newly uploaded pending image, just remove it from pendingImageUploads!
          const pendingIdx = (this.pendingImageUploads || []).findIndex(img => img.path === 'src/' + cleanPath || img.path === cleanPath);
          if (pendingIdx !== -1) {
            this.pendingImageUploads.splice(pendingIdx, 1);
          } else if (file) {
            // 2. Otherwise add to pendingImageDeletes
            this.pendingImageDeletes.push({
              path: `src/${file.path}`
            });
          }
          
          // Remove from local mediaFiles list immediately so it disappears from gallery
          this.mediaFiles = this.mediaFiles.filter(f => f.path !== cleanPath && ('src/' + f.path) !== cleanPath);
        });
        
        this.showToast('Görsel(ler) silinmek üzere işaretlendi. Yayınla butonuna bastığınızda GitHub\'dan silinecektir.', 'success');
        this.activeSelectedImages = [];
      },

      downloadSelectedMedia() {
        if (this.activeSelectedImages.length === 0) return;
        
        this.activeSelectedImages.forEach(relativePath => {
          const cleanPath = relativePath.replace(/^\/+/, '');
          const file = this.mediaFiles.find(f => f.path === cleanPath || ('src/' + f.path) === cleanPath);
          if (!file) return;
          
          const rawUrl = `https://raw.githubusercontent.com/${this.repoOwner}/${this.repoName}/${this.branch}/src/${file.path}`;
          
          const link = document.createElement('a');
          link.href = rawUrl;
          link.download = file.name;
          link.target = '_blank';
          document.body.appendChild(link);
          link.click();
          document.body.removeChild(link);
        });
      },

      previewSelectedMedia() {
        if (this.activeSelectedImages.length === 0) return;
        const relativePath = this.activeSelectedImages[0];
        const cleanPath = relativePath.replace(/^\/+/, '');
        const file = this.mediaFiles.find(f => f.path === cleanPath || ('src/' + f.path) === cleanPath);
        if (!file) return;
        
        const rawUrl = `https://raw.githubusercontent.com/${this.repoOwner}/${this.repoName}/${this.branch}/src/${file.path}`;
        window.open(rawUrl, '_blank');
      },

      copyMediaText(type) {
        if (this.activeSelectedImages.length === 0) return;
        const relativePath = this.activeSelectedImages[0];
        const fileName = relativePath.split('/').pop() || 'Görsel';
        
        let text = '';
        if (type === 'path') {
          text = relativePath;
        } else if (type === 'markdown') {
          text = `![${fileName}](${relativePath})`;
        } else if (type === 'html') {
          text = `<img src="${relativePath}" alt="${fileName}" />`;
        }
        navigator.clipboard.writeText(text).then(() => {
          this.showToast('Panoya başarıyla kopyalandı.', 'success');
        }).catch(err => {
          console.error(err);
          this.showToast('Kopyalama başarısız.', 'error');
        });
      },

      openFullscreenEditor(title, subtitle, initialContent, callback) {
        this.fullscreenEditorTitle = title;
        this.fullscreenEditorSubtitle = subtitle;
        this.fullscreenEditorContent = initialContent || '';
        this.fullscreenEditorCallback = callback;
        this.fullscreenEditorOpen = true;
      },

      closeFullscreenEditor(saveChanges) {
        if (saveChanges && this.fullscreenEditorCallback) {
          this.fullscreenEditorCallback(this.fullscreenEditorContent);
        }
        this.fullscreenEditorOpen = false;
      },

      async uploadNewImage(event) {
        const file = event.target.files[0];
        if (!file) return;
        
        // Make safe slug-like filename
        let nameOnly = file.name.substring(0, file.name.lastIndexOf('.'));
        let ext = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();
        
        let cleanName = nameOnly.toLowerCase()
                                .replace(/[^a-z0-9]/g, '-')
                                .replace(/-+/g, '-')
                                .replace(/^-|-$/g, '') + ext;
        
        this.showLoading('Görsel yerel belleğe hazırlanıyor...');
        
        try {
          const reader = new FileReader();
          reader.onload = async (e) => {
            try {
              const base64Content = e.target.result.split(',')[1];
              const blobUrl = URL.createObjectURL(file);
              const relativePath = `/assets/${cleanName}`;
              
              // 1. Add to pending uploads
              if (!this.pendingImageUploads) this.pendingImageUploads = [];
              this.pendingImageUploads.push({
                name: cleanName,
                path: `src/assets/${cleanName}`,
                content: base64Content,
                blobUrl: blobUrl,
                size: file.size
              });
              
              // 2. Add to in-memory mediaFiles list so it is selectable instantly!
              this.mediaFiles.unshift({
                name: cleanName,
                path: `assets/${cleanName}`,
                size: file.size,
                isPending: true,
                blobUrl: blobUrl
              });
              
              this.showToast('Görsel yerel kütüphaneye eklendi. Değişiklikleri yayınlamak için yukarıdaki gold butonu kullanın.', 'success');
              
              // 3. Immediately select the uploaded image path for the active field
              if (this.mediaTargetObject === 'quill') {
                const quill = this.mediaTargetProperty;
                const range = quill.getSelection();
                const index = range ? range.index : quill.getLength();
                quill.insertEmbed(index, 'image', relativePath);
              } else if (this.mediaTargetIndex !== -1 && this.mediaTargetObject) {
                this.mediaTargetObject[this.mediaTargetIndex] = relativePath;
              } else if (this.mediaTargetProperty && this.mediaTargetObject) {
                this.mediaTargetObject[this.mediaTargetProperty] = relativePath;
              }
              
              this.mediaLibraryOpen = false;
              this.hideLoading();
            } catch (err) {
              this.hideLoading();
              this.showToast('Görsel hazırlanırken hata oluştu.', 'error');
            }
          };
          reader.readAsDataURL(file);
        } catch (err) {
          this.hideLoading();
          this.showToast('Görsel dosyası okunamadı.', 'error');
        }
      },

      formatBytes(bytes) {
        if (bytes === 0) return '0 Bytes';
        const k = 1024;
        const sizes = ['Bytes', 'KB', 'MB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
      },

      // Edit Drawer Functions
      addNewItem() {
        this.isNew = true;
        this.editingIndex = -1;
        this.errors.id = null;
        
        const type = this.getActiveCatalogType();
        
        if (type === 'pieces_list') {
          this.editingItem = {
            id: '',
            no_detail: false,
            _title_field: '', // binding pointer
            collection: this.activeCatalog,
            tagline: '',
            _desc_field: '', // binding pointer
            materials: [''],
            featured: false,
            wolfandbadger: '',
            more4id: '',
            njal: '',
            video_url: '',
            images: [''],
            drive_images: ['']
          };
        } else {
          this.editingItem = {
            id: '',
            _title_field: '', // binding pointer for Title
            date: new Date().toISOString().split('T')[0],
            _desc_field: '', // binding pointer for Summary
            category: 'Philosophy',
            featured_image: '',
            featured: false,
            sections: [{ type: 'text_block', body: '' }]
          };
        }
        
        this.isEditing = true;
      },

      editItem(item, index) {
        this.isNew = false;
        this.editingIndex = index;
        this.errors.id = null;
        
        this.editingItem = JSON.parse(JSON.stringify(item));
        this.editingItem.originalId = item.id;
        
        // Map properties cleanly to common editor binding pointers
        this.editingItem._title_field = item.name || item.title || '';
        this.editingItem._desc_field = item.story || item.summary || '';
        
        if (this.getActiveCatalogType() === 'pieces_list') {
          this.editingItem.no_detail = !!item.no_detail;
          if (!this.editingItem.materials) this.editingItem.materials = [''];
          if (!this.editingItem.images) this.editingItem.images = [''];
          if (!this.editingItem.drive_images) this.editingItem.drive_images = [''];
        } else {
          if (!this.editingItem.sections) this.editingItem.sections = [{ type: 'text_block', body: '' }];
        }
        
        this.isEditing = true;
      },

      closeEditor() {
        this.isEditing = false;
        this.editingItem = {};
        this.errors.id = null;
      },

      // Dynamic Block/Section managers inside editor
      getBlockLabel(type) {
        const map = {
          text_block: 'Metin Bloğu ✍️',
          blockquote: 'Alıntı Bloğu 💬',
          image_block: 'Görsel Bloğu 🖼️',
          video_url: 'Video Bloğu 🎥', // backward compat
          video_block: 'Video Bloğu 🎥',
          subheading: 'Alt Başlık 🔖'
        };
        return map[type] || 'Blok';
      },

      addBlock(type) {
        const def = {
          text_block: { type, body: '' },
          blockquote: { type, quote: '', author: '' },
          image_block: { type, image: '', alt: '', caption: '' },
          video_block: { type, video_url: '', caption: '' },
          subheading: { type, text: '' }
        };
        this.editingItem.sections.push(def[type] || { type, body: '' });
      },

      insertMarkdownFormat(textareaId, formatType) {
        const textarea = document.getElementById(textareaId);
        if (!textarea) return;
        
        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const text = textarea.value;
        const selectedText = text.substring(start, end);
        
        let replacement = '';
        
        switch (formatType) {
          case 'bold':
            replacement = `**${selectedText || 'kalın yazılı metin'}**`;
            break;
          case 'italic':
            replacement = `*${selectedText || 'italik yazılı metin'}*`;
            break;
          case 'heading':
            replacement = `\n### ${selectedText || 'Başlık'}\n`;
            break;
          case 'link':
            replacement = `[${selectedText || 'Bağlantı Başlığı'}](https://)`;
            break;
          case 'quote':
            replacement = `\n> ${selectedText || 'Alıntı metni'}\n`;
            break;
          case 'list':
            replacement = `\n- ${selectedText || 'Liste ögesi'}\n`;
            break;
        }
        
        textarea.value = text.substring(0, start) + replacement + text.substring(end);
        textarea.focus();
        
        // Dispatch 'input' so Alpine.js x-model updates instantly
        textarea.dispatchEvent(new Event('input', { bubbles: true }));
        
        // Select the newly formatted segment
        textarea.setSelectionRange(start, start + replacement.length);
      },

      moveBlockUp(idx) {
        if (idx === 0) return;
        const temp = this.editingItem.sections[idx];
        this.editingItem.sections[idx] = this.editingItem.sections[idx - 1];
        this.editingItem.sections[idx - 1] = temp;
      },

      moveBlockDown(idx) {
        if (idx === this.editingItem.sections.length - 1) return;
        const temp = this.editingItem.sections[idx];
        this.editingItem.sections[idx] = this.editingItem.sections[idx + 1];
        this.editingItem.sections[idx + 1] = temp;
      },

      // Ordering table rows (In-Memory Local Updates)
      moveItemUp(index) {
        if (index === 0) return;
        const items = this.getActiveCatalogData();
        const temp = items[index];
        items[index] = items[index - 1];
        items[index - 1] = temp;
        
        const cat = this.catalogs.find(c => c.name === this.activeCatalog);
        if (cat) cat.dirty = true;
        this.showToast('Sıralama yerel belleğe kaydedildi. Değişiklikleri yukarıdaki gold butonla yayınlayabilirsiniz.', 'success');
      },

      moveItemDown(index) {
        const items = this.getActiveCatalogData();
        if (index === items.length - 1) return;
        const temp = items[index];
        items[index] = items[index + 1];
        items[index + 1] = temp;
        
        const cat = this.catalogs.find(c => c.name === this.activeCatalog);
        if (cat) cat.dirty = true;
        this.showToast('Sıralama yerel belleğe kaydedildi. Değişiklikleri yukarıdaki gold butonla yayınlayabilirsiniz.', 'success');
      },

      autoSlugify() {
        if (!this.editingItem._title_field) return;
        let str = this.editingItem._title_field.toLowerCase().trim();
        const trMap = {
          'ç': 'c', 'ğ': 'g', 'ı': 'i', 'ö': 'o', 'ş': 's', 'ü': 'u',
          'â': 'a', 'î': 'i', 'û': 'u'
        };
        for (let key in trMap) {
          str = str.replace(new RegExp(key, 'g'), trMap[key]);
        }
        this.editingItem.id = str
          .replace(/[^a-z0-9\s-]/g, '')
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-')
          .replace(/^-+|-+$/g, '');
        this.validateSlug();
      },

      validateSlug() {
        if (this.editingItem.no_detail && !this.editingItem.id) {
          this.errors.id = null;
          return;
        }
        if (!this.editingItem.id) {
          this.errors.id = '⚠️ Kalıcı bağlantı (ID) boş olamaz.';
          return;
        }
        this.editingItem.id = this.editingItem.id.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '').replace(/-+/g, '-');
        
        const dup = this.allSlugs.find(s => 
          s.id === this.editingItem.id && 
          !(this.isNew === false && this.editingItem.originalId === s.id && this.activeCatalog === s.catalogName)
        );
        if (dup) {
          this.errors.id = `⚠️ Bu ID başka bir üründe kullanılıyor: "${dup.productName}" (${dup.catalogLabel})`;
        } else {
          this.errors.id = null;
        }
      },

      // Saves Single Static Files Locally
      saveSingleObject() {
        const cat = this.catalogs.find(c => c.name === this.activeCatalog);
        if (!cat) return;
        
        cat.data = JSON.parse(JSON.stringify(this.singleObjectData));
        cat.dirty = true;
        this.showToast('Sayfa ayarları yerel belleğe kaydedildi. Değişiklikleri yayınlamak için yukarıdaki gold butonu kullanın.', 'success');
      },

      // Special local handler for press heading field
      savePressHeadingOnly() {
        const cat = this.catalogs.find(c => c.name === 'press');
        if (!cat) return;
        
        cat.heading = this.pressHeading;
        cat.page_title = this.pressPageTitle;
        cat.meta_description = this.pressMetaDescription;
        cat.dirty = true;
        this.showToast('Basın ayarları yerel belleğe kaydedildi. Değişiklikleri yayınlamak için yukarıdaki gold butonu kullanın.', 'success');
      },

      // Saves Product / Post items locally in-memory
      saveProduct() {
        const type = this.getActiveCatalogType();

        if (type === 'pieces_list' && this.editingItem.no_detail) {
          if (!this.editingItem.id) {
            this.editingItem.id = 'simple-' + Date.now();
          }
          if (!this.editingItem._title_field || !this.editingItem._title_field.trim()) {
            this.editingItem._title_field = 'Detaysız Ürün (' + this.editingItem.id + ')';
          }
        }

        this.validateSlug();
        if (this.errors.id) {
          this.showToast('Formda hatalar var, lütfen düzeltin.', 'error');
          return;
        }
        if (!this.editingItem._title_field.trim()) {
          this.showToast('Lütfen başlığı girin.', 'error');
          return;
        }

        // Re-map binding values back to their schema names
        if (type === 'pieces_list') {
          this.editingItem.name = this.editingItem.no_detail ? "" : this.editingItem._title_field.trim();
          this.editingItem.story = this.editingItem.no_detail ? "" : this.editingItem._desc_field.trim();
          
          this.editingItem.materials = this.editingItem.no_detail ? [] : this.editingItem.materials.map(m => m.trim()).filter(m => m !== '');
          this.editingItem.images = this.editingItem.images.map(i => i.trim()).filter(i => i !== '');
          this.editingItem.drive_images = (this.editingItem.drive_images || []).map(d => d.trim()).filter(d => d !== '');
          
          if (!this.editingItem.no_detail && this.editingItem.materials.length === 0) this.editingItem.materials = ['Gümüş / Bronze Core'];
          if (this.editingItem.images.length === 0 && this.editingItem.drive_images.length === 0) this.editingItem.images = [];
          if (this.editingItem.drive_images.length === 0) delete this.editingItem.drive_images;
        } else {
          this.editingItem.title = this.editingItem._title_field.trim();
          this.editingItem.summary = this.editingItem._desc_field.trim();
        }

        // Strip temporary properties
        delete this.editingItem._title_field;
        delete this.editingItem._desc_field;
        delete this.editingItem.originalId;

        const items = this.getActiveCatalogData();
        if (this.isNew) {
          items.push(this.editingItem);
        } else {
          items[this.editingIndex] = this.editingItem;
        }

        const cat = this.catalogs.find(c => c.name === this.activeCatalog);
        if (cat) cat.dirty = true;

        this.isEditing = false;
        this.showToast('Değişiklikler yerel belleğe kaydedildi. Değişiklikleri yayınlamak için yukarıdaki gold butonu kullanın.', 'success');
      },

      // Delete items locally
      deleteItem(index) {
        const items = this.getActiveCatalogData();
        const title = items[index].name || items[index].title;
        if (!confirm(`"${title}" adlı kaydı silmek istediğinize emin misiniz?`)) return;
        
        items.splice(index, 1);
        
        const cat = this.catalogs.find(c => c.name === this.activeCatalog);
        if (cat) cat.dirty = true;
        this.showToast('Kayıt silindi (yerel). Değişiklikleri yayınlamak için yukarıdaki gold butonu kullanın.', 'success');
      },

      // BATCH PUBLISH TO GITHUB (Atomic Single Commit!)
      async publishAllChanges() {
        const dirty = this.catalogs.filter(c => c.dirty);
        const pendingImages = this.pendingImageUploads || [];
        const pendingDeletes = this.pendingImageDeletes || [];
        
        if (dirty.length === 0 && pendingImages.length === 0 && pendingDeletes.length === 0) {
          this.showToast('Yayınlanacak değişiklik yok.', 'info');
          return;
        }
        
        const summary = [];
        if (dirty.length > 0) summary.push(`${dirty.length} katalog değişikliği`);
        if (pendingImages.length > 0) summary.push(`${pendingImages.length} yeni görsel`);
        if (pendingDeletes.length > 0) summary.push(`${pendingDeletes.length} silinecek görsel`);
        
        if (!confirm(`${summary.join(', ')} için yaptığınız tüm değişiklikleri TEK BİR COMMİT ile GitHub'a göndermek ve canlı sitede yayınlamak istediğinize emin misiniz?`)) {
          return;
        }
        
        this.showLoading('Değişiklikler tek bir paket halinde hazırlanıyor...');
        
        try {
          const headers = {
            'Authorization': `token ${this.token}`,
            'Content-Type': 'application/json'
          };
          const baseApiUrl = `https://api.github.com/repos/${this.repoOwner}/${this.repoName}`;
          
          // 1. Get the latest commit SHA of the target branch
          const refRes = await fetch(`${baseApiUrl}/git/ref/heads/${this.branch}`, { headers });
          if (!refRes.ok) throw new Error('Son commit bilgisi alınamadı.');
          const refJson = await refRes.json();
          const parentCommitSha = refJson.object.sha;
          
          // 2. Get the tree SHA of that parent commit
          const commitRes = await fetch(`${baseApiUrl}/git/commits/${parentCommitSha}`, { headers });
          if (!commitRes.ok) throw new Error('Son ağaç bilgisi alınamadı.');
          const commitJson = await commitRes.json();
          const baseTreeSha = commitJson.tree.sha;
          
          // 3. Create blobs for images, deletions, and modified catalogs
          const treeEntries = [];
          
          // 3.1. Upload staged images as blobs
          if (pendingImages.length > 0) {
            let count = 0;
            for (let img of pendingImages) {
              count++;
              this.showLoading(`Görsel paketleri oluşturuluyor (${count}/${pendingImages.length})...`);
              
              const blobRes = await fetch(`${baseApiUrl}/git/blobs`, {
                method: 'POST',
                headers,
                body: JSON.stringify({
                  content: img.content,
                  encoding: 'base64'
                })
              });
              
              if (!blobRes.ok) throw new Error(`${img.name} blobu oluşturulamadı.`);
              const blobJson = await blobRes.json();
              
              treeEntries.push({
                path: img.path,
                mode: '100644',
                type: 'blob',
                sha: blobJson.sha
              });
            }
          }
          
          // 3.2. Prepare staged deletions in tree entries
          if (pendingDeletes.length > 0) {
            for (let del of pendingDeletes) {
              treeEntries.push({
                path: del.path,
                mode: '100644',
                type: 'blob',
                sha: null // setting sha to null in base_tree tells GitHub to delete the file!
              });
            }
          }
          
          // 3.3. Create blobs for dirty catalogs
          if (dirty.length > 0) {
            let count = 0;
            for (let cat of dirty) {
              count++;
              this.showLoading(`Veri paketleri hazırlanıyor (${count}/${dirty.length})...`);
              
              let payload = {};
              if (cat.type === 'single_object') {
                payload = cat.data;
              } else if (cat.type === 'pieces_list') {
                payload = { pieces: cat.data };
              } else if (cat.type === 'articles_list') {
                payload = { 
                  page_title: cat.page_title, 
                  meta_description: cat.meta_description, 
                  heading: cat.heading, 
                  articles: cat.data 
                };
              } else if (cat.type === 'posts_list') {
                payload = { posts: cat.data };
              }
              
              const jsonString = JSON.stringify(payload, null, 2);
              const base64Content = btoa(unescape(encodeURIComponent(jsonString)));
              
              const blobRes = await fetch(`${baseApiUrl}/git/blobs`, {
                method: 'POST',
                headers,
                body: JSON.stringify({
                  content: base64Content,
                  encoding: 'base64'
                })
              });
              
              if (!blobRes.ok) throw new Error(`${cat.label} veri blobu oluşturulamadı.`);
              const blobJson = await blobRes.json();
              
              treeEntries.push({
                path: cat.path,
                mode: '100644',
                type: 'blob',
                sha: blobJson.sha
              });
            }
          }
          
          // 4. Create the new Tree
          this.showLoading('Yeni git ağacı oluşturuluyor...');
          const treeRes = await fetch(`${baseApiUrl}/git/trees`, {
            method: 'POST',
            headers,
            body: JSON.stringify({
              base_tree: baseTreeSha,
              tree: treeEntries
            })
          });
          if (!treeRes.ok) throw new Error('Yeni git ağacı oluşturulamadı.');
          const treeJson = await treeRes.json();
          const newTreeSha = treeJson.sha;
          
          // 5. Create the Commit
          this.showLoading('Değişiklikler tek bir commit halinde imzalanıyor...');
          const commitMessage = `Batch publish: Updated ${dirty.length} catalogs, added ${pendingImages.length} images, deleted ${pendingDeletes.length} assets via CMS Panel`;
          
          const newCommitRes = await fetch(`${baseApiUrl}/git/commits`, {
            method: 'POST',
            headers,
            body: JSON.stringify({
              message: commitMessage,
              tree: newTreeSha,
              parents: [parentCommitSha]
            })
          });
          if (!newCommitRes.ok) throw new Error('Yeni commit nesnesi oluşturulamadı.');
          const newCommitJson = await newCommitRes.json();
          const newCommitSha = newCommitJson.sha;
          
          // 6. Update the reference (Fast-forward push!)
          this.showLoading('Değişiklikler GitHub deposuna gönderiliyor...');
          const refUpdateRes = await fetch(`${baseApiUrl}/git/refs/heads/${this.branch}`, {
            method: 'PATCH',
            headers,
            body: JSON.stringify({
              sha: newCommitSha,
              force: false
            })
          });
          if (!refUpdateRes.ok) throw new Error('GitHub dal referansı güncellenemedi.');
          
          // 7. Clear staged states on success
          this.pendingImageUploads = [];
          this.pendingImageDeletes = [];
          dirty.forEach(cat => {
            cat.dirty = false;
          });
          
          this.showToast('Tüm değişiklikler, görseller ve silme işlemleri TEK BİR COMMİT ile başarıyla yayınlandı!', 'success');
          await this.loadAllCatalogs();
          await this.loadMediaLibrary();
        } catch (err) {
          console.error(err);
          this.showToast(`Yayınlama sırasında hata: ${err.message}`, 'error');
        } finally {
          this.hideLoading();
        }
      },

      // Premium Notifications Toasts
      showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        if (!container) return;
        const toast = document.createElement('div');
        
        let bgColor = 'bg-slate-900/90 border-slate-800 text-slate-100';
        let icon = '<i class="fa-solid fa-circle-check text-green-400 text-base"></i>';
        if (type === 'success') {
          bgColor = 'bg-slate-900/90 border-gold-500/20 text-slate-100';
          icon = '<i class="fa-solid fa-circle-check text-gold-400 text-base"></i>';
        } else if (type === 'error') {
          bgColor = 'bg-red-950/90 border-red-900/20 text-red-100';
          icon = '<i class="fa-solid fa-circle-exclamation text-red-400 text-base"></i>';
        }

        toast.className = `flex items-center gap-3 px-4 py-3.5 rounded-xl border backdrop-blur-md shadow-xl max-w-sm transition-all duration-300 transform translate-y-2 opacity-0 ${bgColor}`;
        toast.innerHTML = `
          ${icon}
          <span class="text-xs font-semibold leading-relaxed">${message}</span>
        `;
        container.appendChild(toast);
        setTimeout(() => toast.classList.remove('translate-y-2', 'opacity-0'), 50);
        setTimeout(() => {
          toast.classList.add('opacity-0', 'translate-y-[-4px]');
          setTimeout(() => toast.remove(), 300);
        }, 4000);
      }
    };
  }
</script>
