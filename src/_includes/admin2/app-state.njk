        const cat = this.catalogs.find(c => c.name === this.activeCatalog);
        return cat ? cat.label : '';
      },

      getActiveCatalogType() {
        const cat = this.catalogs.find(c => c.name === this.activeCatalog);
        return cat ? cat.type : '';
      },

      selectCatalog(name) {
        this.activeCatalog = name;
        this.searchQuery = '';
        
        const cat = this.catalogs.find(c => c.name === name);
        if (cat) {
          if (cat.type === 'single_object') {
            this.singleObjectData = JSON.parse(JSON.stringify(cat.data));
          } else if (name === 'press') {
            // Press has list and heading
            this.pressHeading = cat.heading || '';
            this.pressPageTitle = cat.page_title || '';
            this.pressMetaDescription = cat.meta_description || '';
          }
        }
      },

      getActiveCatalogData() {
        const cat = this.catalogs.find(c => c.name === this.activeCatalog);
        return cat ? cat.data : [];
      },

      filteredItems() {
        const items = this.getActiveCatalogData();
        if (!this.searchQuery.trim()) return items;
        
        const q = this.searchQuery.trim().toLowerCase();
        return items.filter(item => 
          (item.name && item.name.toLowerCase().includes(q)) || 
          (item.title && item.title.toLowerCase().includes(q)) ||
          (item.id && item.id.toLowerCase().includes(q))
        );
      },

      getItemImage(item) {
