<!-- LIST COLLECTIONS VIEW (Takı, Blog, Basın) -->
<!-- Corrected x-show to strictly hide list view on dashboard catalog screen -->
<div x-show="activeCatalog !== 'dashboard' && getActiveCatalogType() !== 'single_object'" class="space-y-6" x-cloak>
  
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h3 class="font-serif text-2xl font-semibold text-slate-100" x-text="activeCatalogLabel"></h3>
      <p class="text-xs text-slate-500 mt-1">İlgili listeyi tablodan düzenleyin. Sıralama butonlarıyla ögeleri reorder edebilirsiniz.</p>
    </div>
    
    <button @click="addNewItem()" 
      class="self-start sm:self-auto px-4 py-3 bg-gold-500 hover:bg-gold-400 active:scale-95 border border-transparent rounded-xl text-slate-950 text-xs font-semibold tracking-wide transition-all flex items-center space-x-2">
      <i class="fa-solid fa-plus"></i>
      <span>Yeni Kayıt Ekle</span>
    </button>
  </div>

  <!-- Press Header Settings if active catalog is Press -->
  <div x-show="activeCatalog === 'press'" class="bg-slate-900/20 border border-slate-800 p-5 rounded-2xl space-y-4">
    <div class="flex items-center justify-between">
      <h4 class="text-xs font-semibold uppercase tracking-wider text-slate-300 font-sans">Basın Sayfası Ayarları</h4>
      <button @click="savePressHeadingOnly()" class="px-3.5 py-1.5 bg-slate-950 border border-slate-800 hover:border-gold-500/20 text-gold-400 text-[11px] font-semibold rounded-lg">
        Sayfa Ayarlarını Kaydet
      </button>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="space-y-1.5">
        <label class="text-[10px] uppercase text-slate-500 font-semibold tracking-wider">Basın Ana Başlığı</label>
        <input type="text" x-model="pressHeading" class="block w-full bg-slate-950/60 border border-slate-800 rounded-xl py-2 px-3 text-xs text-slate-200 focus:outline-none" />
      </div>
      <div class="space-y-1.5">
        <label class="text-[10px] uppercase text-slate-500 font-semibold tracking-wider">Sayfa Başlığı (Browser Title)</label>
        <input type="text" x-model="pressPageTitle" class="block w-full bg-slate-950/60 border border-slate-800 rounded-xl py-2 px-3 text-xs text-slate-200 focus:outline-none" />
      </div>
      <div class="space-y-1.5">
        <label class="text-[10px] uppercase text-slate-500 font-semibold tracking-wider">Meta Açıklaması (Description)</label>
        <input type="text" x-model="pressMetaDescription" class="block w-full bg-slate-950/60 border border-slate-800 rounded-xl py-2 px-3 text-xs text-slate-200 focus:outline-none" />
      </div>
    </div>
  </div>

  <!-- Catalog Table / List Container -->
  <div class="bg-slate-900/20 border border-slate-800 rounded-2xl overflow-hidden">
    
    <div class="p-4 border-b border-slate-800/80 flex items-center relative">
      <i class="fa-solid fa-search text-slate-500 absolute left-8"></i>
      <input type="text" x-model="searchQuery" placeholder="Başlık veya ID ara..." 
        class="w-full bg-slate-950/40 border border-slate-800 rounded-xl py-2.5 pl-10 pr-4 text-xs text-slate-300 placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-gold-500 focus:border-gold-500 transition-all" />
    </div>

    <!-- List Screen -->
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-slate-800/80 text-[10px] font-semibold text-slate-400 uppercase tracking-widest bg-slate-900/10">
            <th class="py-3 px-3 sm:py-4 sm:px-6 w-12 sm:w-16">Görsel</th>
            <th class="py-3 px-3 sm:py-4 sm:px-6">Ürün / Yazı Adı</th>
            <th class="py-3 px-3 sm:py-4 sm:px-6 hidden md:table-cell">Özet / Tanıtım</th>
            <th class="py-3 px-3 sm:py-4 sm:px-6 text-center w-12 sm:w-16">Öne Çıkan</th>
            <th class="py-3 px-3 sm:py-4 sm:px-6 text-center w-20 sm:w-28">Sıralama</th>
            <th class="py-3 px-3 sm:py-4 sm:px-6 text-right w-20 sm:w-24">Aksiyonlar</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800/50">
          <template x-for="(item, index) in filteredItems()" :key="item.id + '-' + index">
            <tr class="hover:bg-slate-900/10 transition-colors">
              <!-- Thumbnail Image -->
              <td class="py-3 px-3 sm:py-4 sm:px-6">
                <div class="w-10 h-10 sm:w-12 sm:h-12 bg-slate-950 rounded-lg border border-slate-800/80 overflow-hidden flex items-center justify-center flex-shrink-0">
                  <img :src="getItemImage(item)" 
                    class="w-full h-full object-cover" 
                    onerror="this.src='https://placehold.co/100x100/1e293b/a88653?text=Yok'" />
                </div>
              </td>
              <!-- Product/Article Title & ID -->
              <td class="py-3 px-3 sm:py-4 sm:px-6">
                <span class="text-xs sm:text-sm font-semibold text-slate-200 block truncate max-w-[120px] sm:max-w-[200px]" x-text="item.name || item.title"></span>
                <code class="text-[9px] sm:text-[10px] text-gold-400 font-mono" x-text="item.id"></code>
              </td>
              <!-- Tagline/Summary -->
              <td class="py-3 px-3 sm:py-4 sm:px-6 hidden md:table-cell max-w-xs">
                <span class="text-xs text-slate-400 line-clamp-2 leading-relaxed" x-text="item.tagline || item.summary"></span>
              </td>
              <!-- Featured Badge -->
              <td class="py-3 px-3 sm:py-4 sm:px-6 text-center">
                <span x-show="item.featured" class="inline-flex items-center px-2 py-0.5 rounded-full text-[9px] sm:text-[10px] font-medium bg-gold-500/10 text-gold-300 border border-gold-500/20">
                  Evet
                </span>
                <span x-show="!item.featured" class="text-xs text-slate-600">—</span>
              </td>
              <!-- Move Up / Down Buttons -->
              <td class="py-3 px-3 sm:py-4 sm:px-6 text-center">
                <div class="inline-flex rounded-xl bg-slate-950 border border-slate-800 p-0.5">
                  <button @click="moveItemUp(index)" title="Yukarı Taşı"
                    class="w-7 h-7 sm:w-8 sm:h-8 rounded-lg flex items-center justify-center text-[10px] sm:text-xs text-slate-400 hover:text-gold-400 hover:bg-slate-900 disabled:opacity-20 disabled:hover:bg-transparent transition-all"
                    :disabled="index === 0 || searchQuery !== ''">
                    <i class="fa-solid fa-arrow-up"></i>
                  </button>
                  <button @click="moveItemDown(index)" title="Aşağı Taşı"
                    class="w-7 h-7 sm:w-8 sm:h-8 rounded-lg flex items-center justify-center text-[10px] sm:text-xs text-slate-400 hover:text-gold-400 hover:bg-slate-900 disabled:opacity-20 disabled:hover:bg-transparent transition-all"
                    :disabled="index === getActiveCatalogData().length - 1 || searchQuery !== ''">
                    <i class="fa-solid fa-arrow-down"></i>
                  </button>
                </div>
              </td>
              <!-- Edit / Delete Actions -->
              <td class="py-3 px-3 sm:py-4 sm:px-6 text-right">
                <div class="inline-flex space-x-1">
                  <button @click="editItem(item, index)" title="Düzenle"
                    class="w-7 h-7 sm:w-8 sm:h-8 rounded-lg sm:rounded-xl bg-slate-950 border border-slate-800 hover:border-gold-500/30 hover:bg-gold-950/20 text-slate-400 hover:text-gold-400 flex items-center justify-center transition-all">
                    <i class="fa-solid fa-pen text-[10px] sm:text-xs"></i>
                  </button>
                  <button @click="deleteItem(index)" title="Sil"
                    class="w-7 h-7 sm:w-8 sm:h-8 rounded-lg sm:rounded-xl bg-slate-950 border border-slate-800 hover:border-red-500/30 hover:bg-red-950/20 text-slate-400 hover:text-red-400 flex items-center justify-center transition-all">
                    <i class="fa-solid fa-trash text-[10px] sm:text-xs"></i>
                  </button>
                </div>
              </td>
            </tr>
          </template>
          
          <tr x-show="filteredItems().length === 0">
            <td colspan="6" class="py-12 text-center text-slate-500 text-xs">
              <i class="fa-solid fa-folder-open text-2xl mb-3 block text-slate-700"></i>
              Aradığınız kriterlere uygun kayıt bulunamadı.
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
