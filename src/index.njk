---
layout: base.njk
permalink: "/index.html"
---

<!-- Hero Section -->
<section class="hero" id="hero">
  <div class="hero-bg" style="background-image: url('{{ manifesto.image | default('/assets/banner.webp') }}');"></div>
  <div class="hero-content">
    <h1 class="hero-title reveal">{{ settings.hero_title | default("Where Human Thinking Meets Machine Precision.") }}</h1>
    <p class="hero-sub reveal reveal-delay-1">{{ settings.hero_subtitle | default("AI Business Studio London") }}</p>
    {% if settings.hero_description %}
    <p class="hero-desc reveal reveal-delay-2" style="font-family: var(--font-serif); font-style: italic; font-size: clamp(1rem, 2vw, 1.3rem); color: rgba(255, 255, 255, 0.7); max-width: 650px; line-height: 1.5; margin-top: 0.5rem; text-shadow: 0 1px 10px rgba(0,0,0,0.4);">
      {{ settings.hero_description }}
    </p>
    {% endif %}
  </div>
  <div class="hero-scroll">
    <span>Scroll</span>
    <div class="hero-scroll-line"></div>
  </div>
</section>

<!-- Manifesto Section (Inspiration from reference site "The Craft" layout) -->
<section class="section manifesto-section" id="manifesto">
  <div class="container">
    <div class="manifesto-layout">
      <div class="manifesto-left reveal">
        <span class="label">{{ settings.manifesto_label | default("Manifesto") }}</span>
      </div>
      <div class="manifesto-right reveal reveal-delay-1">
        <p class="manifesto-line">{{ manifesto.line1 }}</p>
        <p class="manifesto-line">{{ manifesto.line2 }}</p>
        <p class="manifesto-line">{{ manifesto.line3 }}</p>
        {% if manifesto.line4 %}
        <p class="manifesto-line" style="margin-top: 2rem; color: var(--c-muted); font-size: clamp(1.2rem, 2.5vw, 1.8rem);">{{ manifesto.line4 }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<!-- Intellectual Trust Section (Inspiration from press/recognition grid) -->
<section class="section trust-section" id="trust" style="background-color: var(--c-surface); border-top: 1px solid var(--c-border); border-bottom: 1px solid var(--c-border);">
  <div class="container">
    <div class="section-header center reveal">
      <span class="label">{{ settings.trust_label | default("Intellectual Trust") }}</span>
      <h2>{{ settings.trust_title | default("Governance & Blueprint") }}</h2>
    </div>
    
    <div class="trust-grid">
      {% for card in trust.cards %}
      <div class="trust-card reveal {% if loop.index == 2 %}reveal-delay-1{% endif %}">
        <h3 class="trust-card-title">{{ card.title }}</h3>
        <p class="trust-card-text">{{ card.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Service Approach Section (Inspiration from featured work layout) -->
<section class="section approach-section" id="approach">
  <div class="container">
    <div class="section-header reveal">
      <span class="label">{{ settings.approach_label | default("Approach") }}</span>
      <h2>{{ settings.approach_title | default("Core Specialties") }}</h2>
    </div>

    <div class="services-list">
      {% for service in services.services %}
      <div class="service-item reveal {% if loop.index == 2 %}reveal-delay-1{% elif loop.index == 3 %}reveal-delay-2{% endif %}">
        <div class="service-number">0{{ loop.index }}</div>
        <div class="service-details">
          <h3 class="service-title">{{ service.title }}</h3>
          <p class="service-desc">
            {{ service.description }}
            {% if service.tooltip %}
            <span class="tooltip-container">
              <span class="tooltip-trigger">*</span>
              <span class="tooltip-content">
                {{ service.tooltip }}
              </span>
            </span>
            {% endif %}
          </p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Who This Is For Section -->
<section class="section who-for-section" id="who-for" style="background-color: var(--c-cream); border-top: 1px solid var(--c-border); border-bottom: 1px solid var(--c-border);">
  <div class="container">
    <div class="section-header reveal">
      <span class="label">{{ who_for.label | default("Audience") }}</span>
      <h2>{{ who_for.heading | default("Who This Is For") }}</h2>
    </div>
    <div class="who-for-content reveal" style="max-width: 800px; margin-top: 2rem;">
      <p style="font-family: var(--font-serif); font-size: clamp(1.4rem, 2.8vw, 2.2rem); font-weight: 300; line-height: 1.5; color: var(--c-ink); margin-bottom: 2rem;">
        {{ who_for.paragraph_1 | default("We work best with independent brands, founders and small teams who need professional-grade visual systems and AI strategy — without the budget for traditional agencies or in-house teams.") }}
      </p>
      <p style="font-family: var(--font-sans); font-size: 1.05rem; line-height: 1.8; color: var(--c-muted);">
        {{ who_for.paragraph_2 | default("If you already have a clear vision for your brand and need the right framework to execute it faster, this is for you. We help you transition from tools exploration to actual operational leverage.") }}
      </p>
    </div>
  </div>
</section>

<!-- Social Proof Section -->
<section class="section social-proof-section" id="social-proof" style="padding: 4rem 0; border-bottom: 1px solid var(--c-border);">
  <div class="container">
    <div class="section-header center reveal" style="margin-bottom: 0;">
      <span class="label">{{ social_proof.label | default("Recognition") }}</span>
      <h2 style="font-size: 1rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--c-silver); font-family: var(--font-sans); font-weight: 500;">
        {{ social_proof.heading | default("As Featured In / Recognised By") }}
      </h2>
      <div class="press-logos" style="display: flex; gap: 3.5rem; justify-content: center; align-items: center; margin-top: 2.5rem; opacity: 0.35; flex-wrap: wrap;">
        {% for logo in social_proof.logos %}
        <span style="font-family: var(--font-serif); font-style: italic; font-size: 1.15rem; letter-spacing: 0.05em;">{{ logo.name }}</span>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- How We Work Section -->
<section class="section process-section" id="process" style="background-color: var(--c-surface); border-bottom: 1px solid var(--c-border);">
  <div class="container">
    <div class="section-header reveal">
      <span class="label">{{ process.label | default("Methodology") }}</span>
      <h2>{{ process.heading | default("How We Work") }}</h2>
    </div>
    <div class="process-timeline" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; margin-top: var(--space-lg);">
      {% for step in process.steps %}
      <div class="process-step-item reveal{% if loop.index0 > 0 %} reveal-delay-{{ loop.index0 }}{% endif %}">
        <div class="process-step-num" style="font-family: var(--font-serif); font-size: 2.5rem; font-weight: 300; color: var(--c-border); margin-bottom: 0.5rem; line-height: 1;">{{ step.num }}</div>
        <h3 style="font-family: var(--font-serif); font-size: 1.3rem; margin-bottom: 0.8rem; font-weight: 400;">{{ step.title }}</h3>
        <p style="font-family: var(--font-sans); font-size: 0.85rem; color: var(--c-muted); line-height: 1.6;">{{ step.description }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- FAQ Section -->
<section class="section faq-section" id="faq" style="background-color: var(--c-cream); border-bottom: 1px solid var(--c-border);">
  <div class="container" style="max-width: 800px; margin: 0 auto;">
    <div class="section-header center reveal">
      <span class="label">{{ faq.label | default("Clarifications") }}</span>
      <h2>{{ faq.heading | default("Frequently Asked Questions") }}</h2>
    </div>
    <div class="faq-accordion reveal" style="margin-top: 3rem; display: flex; flex-direction: column; gap: 1rem;">
      {% for item in faq.items %}
      <div class="faq-item" style="border: 1px solid var(--c-border); background: var(--c-surface); padding: 1.5rem; transition: all 0.3s ease;">
        <div class="faq-question" style="display: flex; justify-content: space-between; align-items: center; font-family: var(--font-serif); font-size: 1.25rem; font-weight: 400; color: var(--c-ink); cursor: pointer;" onclick="toggleFaq(this)">
          <span>{{ item.question }}</span>
          <span class="faq-icon" style="font-family: var(--font-sans); font-size: 1rem; color: var(--c-muted); transition: transform 0.3s; pointer-events: none;">+</span>
        </div>
        <div class="faq-answer" style="max-height: 0; overflow: hidden; transition: max-height 0.3s ease, margin-top 0.3s ease; font-family: var(--font-sans); font-size: 0.95rem; color: var(--c-muted); line-height: 1.6;">
          <p style="padding-top: 1rem;">{{ item.answer }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  function toggleFaq(el) {
    const item = el.parentElement;
    const answer = item.querySelector('.faq-answer');
    const icon = item.querySelector('.faq-icon');
    
    if (answer.style.maxHeight && answer.style.maxHeight !== '0px') {
      answer.style.maxHeight = '0px';
      icon.style.transform = 'rotate(0deg)';
    } else {
      answer.style.maxHeight = answer.scrollHeight + 'px';
      icon.style.transform = 'rotate(45deg)';
    }
  }
</script>

<!-- Contact / Invitation Only Section -->
<section class="section contact-section" id="contact" style="background-color: var(--c-surface); border-top: 1px solid var(--c-border);">
  <div class="container">
    <div class="contact-content reveal">
      <span class="label">{{ settings.contact_label | default("Contact") }}</span>
      <h2 class="contact-invitation" style="margin-bottom: 1.5rem;">{{ settings.contact_title | default("By Invitation Only.") }}</h2>
      
      <p class="contact-timeline" style="max-width: 600px; margin: 0 auto 2.5rem; color: var(--c-muted); font-size: 0.92rem; font-family: var(--font-sans);">
        We respond personally to every enquiry within 3 business days.
      </p>
      
      <!-- Invitation Request Form -->
      <form id="invitation-form" class="invitation-form" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="{{ settings.web3forms_key }}">
        <input type="hidden" name="subject" value="New Invitation Request — AI Business Studio">
        <input type="hidden" name="from_name" value="AI Business Studio London">
        <input type="checkbox" name="botcheck" class="hidden-field" style="display: none;">

        <div class="form-group-row">
          <div class="form-group">
            <label class="form-label" for="invite-name">Full Name</label>
            <input class="form-input" type="text" id="invite-name" name="name" required autocomplete="name">
          </div>
          <div class="form-group">
            <label class="form-label" for="invite-email">Business Email</label>
            <input class="form-input" type="email" id="invite-email" name="email" required autocomplete="email">
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="invite-org">Organization</label>
          <input class="form-input" type="text" id="invite-org" name="company" placeholder="e.g. Acme Corp">
        </div>

        <div class="form-group">
          <label class="form-label" for="invite-details">Brief Project Context</label>
          <textarea class="form-textarea" id="invite-details" name="message" rows="4" required placeholder="Describe your business challenge or context..."></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-dark" id="invite-submit">
            <span class="submit-text">{{ settings.contact_button | default("Request Invitation") }}</span>
            <span class="btn-loader">
              <svg class="spinner" viewBox="0 0 50 50">
                <circle class="path" cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="5"></circle>
              </svg>
            </span>
          </button>
        </div>

        <div class="form-actions-notes" style="margin-top: 2rem; font-size: 0.82rem; color: var(--c-muted); text-align: center; line-height: 1.6; font-family: var(--font-sans);">
          <p>No sales pitch. Just a conversation to see if there's a genuine fit — for either of us.</p>
          <p style="margin-top: 0.4rem;">Even if you're not ready to start, feel free to reach out with a question.</p>
        </div>
      </form>

      <!-- Alert states -->
      <div class="form-result success-result" style="display: none;">
        <svg class="alert-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        <h3>{{ settings.success_title | default("Request Received") }}</h3>
        <p>{{ settings.success_text | default("Your request has been securely submitted. Our partnership team evaluates inquiries weekly and will reach out if there is a strategic alignment.") }}</p>
      </div>

      <div class="form-result error-result" style="display: none;">
        <svg class="alert-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <h3>{{ settings.error_title | default("Submission Failed") }}</h3>
        <p class="error-msg">{{ settings.error_text | default("An error occurred while sending your request. Please check your network connection and try again.") }}</p>
      </div>

    </div>
  </div>
</section>
